{
  "schemaVersion": 1,
  "name": "Roary",
  "author": "Fintech Farm",
  "version": "0.3.0",
  "description": "Roary the lion — Roarbank mascot desktop pet (eye-tracking idle)",

  "viewBox": { "x": 0, "y": 0, "width": 600, "height": 600 },

  "eyeTracking": {
    "enabled": true,
    "states": ["idle"],
    "eyeRatioX": 0.516,
    "eyeRatioY": 0.430,
    "maxOffset": 4.0,
    "ids": { "eyes": "eyes-js" }
  },

  "sleepSequence": { "mode": "direct" },

  "states": {
    "idle":         ["idle-follow.svg"],
    "thinking":     ["thinking.apng"],
    "working":      ["working.apng"],
    "juggling":     ["juggling.apng"],
    "error":        ["error.apng"],
    "attention":    ["attention.apng"],
    "notification": { "fallbackTo": "attention" },
    "sweeping":     { "fallbackTo": "working" },
    "carrying":     { "fallbackTo": "working" },
    "sleeping":     ["sleeping.png"]
  },

  "workingTiers": [
    { "minSessions": 2, "file": "juggling.apng" },
    { "minSessions": 1, "file": "working.apng" }
  ],

  "idleAnimations": [
    { "file": "idle.apng", "duration": 6000 },
    { "file": "idle-reading.apng", "duration": 14000 }
  ],

  "timings": {
    "mouseIdleTimeout": 20000,
    "mouseSleepTimeout": 60000,
    "minDisplay": { "attention": 4000, "error": 5000, "working": 1000, "thinking": 1000 },
    "autoReturn": { "attention": 4000, "error": 5000 }
  },

  "objectScale": {
    "widthRatio": 1.0,
    "heightRatio": 1.0,
    "imgWidthRatio": 1.0,
    "offsetX": 0.0,
    "offsetY": 0.0,
    "objBottom": 0.0,
    "imgBottom": 0.0
  },

  "hitBoxes": {
    "default":  { "x": 120, "y": 160, "w": 360, "h": 420 },
    "sleeping": { "x": 45,  "y": 330, "w": 510, "h": 255 }
  },
  "sleepingHitboxFiles": ["sleeping.png"],

  "reactions": {
    "clickLeft":  { "file": "react.apng", "duration": 2500 },
    "clickRight": { "file": "react.apng", "duration": 2500 },
    "double":     { "files": ["juggling.apng"], "duration": 3000 }
  },

  "miniMode": { "supported": false },

  "sounds": {
    "complete": "roary-roar.mp3",
    "confirm": "roary-confirm.mp3"
  }
}
